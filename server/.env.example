# Server Environment Setup
PORT=5000
NODE_ENV=development

# Database URIs
MONGO_URI=mongodb://127.0.0.1:27017/fifozone
REDIS_URL=redis://127.0.0.1:6379

# Authentication JWT details
JWT_SECRET=supersecretfifozonekeychangeinproduction
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Cloudinary Integration (Fallbacks to local uploads if empty)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email SMTP Credentials (Gmail OAuth2 / SMTP Fallback)
EMAIL_SERVICE=gmail
EMAIL_USER=alerts@fifozone.com
EMAIL_PASS=secretpassword

# Twilio WhatsApp Configs (Simulated if left empty)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# WooCommerce Credentials (Simulated if left empty)
WOOCOMMERCE_URL=https://fifozone.in
WOOCOMMERCE_CONSUMER_KEY=ck_dummy_key
WOOCOMMERCE_CONSUMER_SECRET=cs_dummy_secret

# Amazon SP-API Credentials (Simulated if left empty)
AMAZON_SELLER_ID=
AMAZON_CLIENT_ID=
AMAZON_CLIENT_SECRET=
AMAZON_REFRESH_TOKEN=
AMAZON_AWS_ACCESS_KEY_ID=
AMAZON_AWS_SECRET_ACCESS_KEY=
AMAZON_ROLE_ARN=

# Flipkart Seller API Credentials (Simulated if left empty)
FLIPKART_CLIENT_ID=
FLIPKART_CLIENT_SECRET=
FLIPKART_APP_ID=
