{
  "name": "fifozone-dashboard-server",
  "version": "1.0.0",
  "description": "Fifozone Inventory & Order Management Backend Server",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev:mock": "nodemon src/mocks/server.js",
    "dev:all": "concurrently --names \"MAIN,MOCK\" --prefix-colors \"cyan,magenta\" \"nodemon server.js\" \"nodemon src/mocks/server.js\"",
    "start:all": "concurrently --names \"MAIN,MOCK\" \"node server.js\" \"node src/mocks/server.js\"",
    "test": "jest --detectOpenHandles --forceExit"
  },
  "keywords": [
    "mern",
    "inventory",
    "order-management",
    "woocommerce",
    "amazon-sp-api",
    "flipkart-seller"
  ],
  "author": "Fifozone Team",
  "license": "ISC",
  "dependencies": {
    "@woocommerce/woocommerce-rest-api": "^1.0.2",
    "amazon-sp-api": "^1.2.1",
    "axios": "^1.16.1",
    "bcryptjs": "^2.4.3",
    "bwip-js": "^3.4.3",
    "cloudinary": "^2.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.4.1",
    "joi": "^17.13.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.13",
    "socket.io": "^4.7.5",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "twilio": "^5.0.4",
    "winston": "^3.13.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "concurrently": "^10.0.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.0.0"
  }
}
